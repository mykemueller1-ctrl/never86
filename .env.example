# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic (Claude API for invoice/z-report parsing)
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx

# Vercel Cron Auth
CRON_SECRET=replace-with-long-random-value

# Internal API auth for protected ingestion/reporting routes
INTERNAL_API_KEY=replace-with-long-random-value

# Tenant/user scope for daily briefing cron
BRIEFING_USER_ID=replace-with-real-user-id

# Notification recipient
OWNER_EMAIL=myke@n86.app
